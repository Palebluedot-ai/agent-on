{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent-on/kit/schemas/memory-card.schema.json",
  "title": "memory_card",
  "description": "沉淀契约:一次 run 收官后把可复用的决策/模式/教训固化成卡时产生。仅 reviewer=pass 且满足写入门禁才写。源流:一代 agent-orchestration-playbook/04_contracts/memory-card-schema.json,memory_type/evidence/confidence 三处并 evolving-memory-system/04_protocols/agent-cards-schema-v1.json。2026-07-07 批二移植去平台化。",
  "type": "object",
  "required": [
    "source_task_id",
    "source_run_id",
    "title",
    "memory_type",
    "summary",
    "scope_level",
    "facts",
    "evidence",
    "confidence",
    "sync_status",
    "curator",
    "trace"
  ],
  "properties": {
    "source_task_id": {"type": "string", "minLength": 1},
    "source_run_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "memory_type": {
      "type": "string",
      "enum": ["decision", "pattern", "anti_pattern", "lesson", "reference"],
      "description": "沉淀的种类(并自 evolving-memory-system):decision=拍板;pattern=可复用做法;anti_pattern=踩过的坑;lesson=一次性教训;reference=资料指针。"
    },
    "summary": {"type": "string", "minLength": 1},
    "scope_level": {
      "type": "string",
      "enum": ["track_local", "shared"],
      "description": "track_local 是本轨候选记忆;shared 是经门禁晋升、带 trace 的记忆(可回馈 agent-on 或写入项目 wiki)。"
    },
    "facts": {"type": "array", "items": {"type": "string"}, "minItems": 1, "description": "耐久事实/结论(一代 durable_facts)。"},
    "procedures_or_patterns": {"type": "array", "items": {"type": "string"}},
    "evidence": {
      "type": "array",
      "description": "证据链(并自 evolving-memory-system):每条指明来源类别与值,支撑 facts 可追责。",
      "items": {
        "type": "object",
        "required": ["kind", "value"],
        "properties": {
          "kind": {"type": "string", "enum": ["file", "url", "log", "tool_output", "commit"]},
          "value": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "suggested_location": {"type": "string", "enum": ["loop_notes", "wiki", "project", "agent_on"], "description": "建议落点:loop_notes=项目内当场记;wiki/project=项目知识库;agent_on=结账时回馈本脚手架仓。"},
    "sync_status": {"type": "string", "enum": ["pending", "synced", "failed"]},
    "curator": {
      "type": "object",
      "required": ["agent_id", "role"],
      "properties": {
        "agent_id": {"type": "string", "minLength": 1},
        "role": {
          "type": "string",
          "enum": ["curator", "system", "human"]
        }
      },
      "additionalProperties": false
    },
    "trace": {
      "type": "object",
      "required": ["run_id", "worktree_path", "phase_card"],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "worktree_path": {"type": "string", "minLength": 1},
        "phase_card": {"type": "string", "minLength": 1},
        "review_ref": {"type": "string"},
        "promotion_ref": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"scope_level": {"const": "shared"}}},
      "then": {
        "properties": {
          "trace": {
            "required": ["review_ref", "promotion_ref"]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
